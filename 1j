pipeline {
    agent any
    environment {
        EMAIL_RECEIPTS    = 'MARS'
        EMAIL_CC_RECEIPTS = 'MARS'
    }

    stages {
        stage('Patch Schedule') {
            steps {
                script {
                    def DATE_TIME       = sh(script: "date",     returnStdout: true).trim()
                    def PATCHING_YEAR   = sh(script: "date +%Y", returnStdout: true).trim()
                    def PATCH_MONTH     = sh(script: "date +%m", returnStdout: true).trim()
                    def PATCH_MONTH_RF2 = sh(script: "date +%b", returnStdout: true).trim()

                    env.PATCHING_YEAR   = PATCHING_YEAR
                    env.PATCH_MONTH     = PATCH_MONTH
                    env.PATCH_MONTH_RF2 = PATCH_MONTH_RF2

                    def NONPROD_DATE = sh(script: "cal ${PATCH_MONTH} ${PATCHING_YEAR} | awk 'NR>2 {print \$3}' | grep -v '^\$' | sed -n '2p'", returnStdout: true).trim()

                    def PROD_DATE = sh(script: "cal ${PATCH_MONTH} ${PATCHING_YEAR} | awk 'NR>2 {print \$5}' | grep -v '^\$' | sed -n '3p'", returnStdout: true).trim()

                    env.NONPROD_PATCH_SCHEDULE = "${PATCH_MONTH_RF2}-${NONPROD_DATE}-${PATCHING_YEAR}"
                    env.PROD_PATCH_SCHEDULE    = "${PATCH_MONTH_RF2}-${PROD_DATE}-${PATCHING_YEAR}"

                    echo "======================================"
                    echo "Date/Time : ${DATE_TIME}"
                    echo "======================================"
                    echo "Non-PROD (2nd Tuesday)  :: ${env.NONPROD_PATCH_SCHEDULE}"
                    echo "PROD     (3rd Thursday) :: ${env.PROD_PATCH_SCHEDULE}"
                    echo "======================================"
                }
            }
        }

        stage('Send mail for IRI Team Servers') {
            environment {
                GROUP_NAME        = 'iri:123'
                EMAIL_RECEIPTS    = 'MARS'
                EMAIL_CC_RECEIPTS = 'MARS'
            }
            steps {
                sh "sudo ansible-playbook -i /etc/ansible/ansible/jenkins /etc/ansible/ansible/playbooks/patching_notifications/main.yml -u MARS --private-key '/home/MARS/.ssh/id_rsa' --vault-password-file '/home/MARS/.vault_pass' -e 'GROUP_NAME=${GROUP_NAME} PATCH_MONTH_BKP=${env.PATCH_MONTH_RF2} NONPROD_PATCH_SCHEDULE=${env.NONPROD_PATCH_SCHEDULE} PROD_PATCH_SCHEDULE=${env.PROD_PATCH_SCHEDULE}'"
            }
        }

        stage('Send mail for MARS Team Servers') {
            environment {
                GROUP_NAME        = 'MARS'
                EMAIL_RECEIPTS    = 'MARS'
                EMAIL_CC_RECEIPTS = 'MARS'
            }
            steps {
                sh "sudo ansible-playbook -i /etc/ansible/ansible/jenkins /etc/ansible/ansible/playbooks/patching_notifications/main.yml -u MARS --private-key '/home/MARS/.ssh/id_rsa' --vault-password-file '/home/MARS/.vault_pass' -e 'GROUP_NAME=${GROUP_NAME} PATCH_MONTH_BKP=${env.PATCH_MONTH_RF2} NONPROD_PATCH_SCHEDULE=${env.NONPROD_PATCH_SCHEDULE} PROD_PATCH_SCHEDULE=${env.PROD_PATCH_SCHEDULE}'"
            }
        }

        stage('Send mail for MASS Team Servers') {
            environment {
                GROUP_NAME        = 'MASS'
                EMAIL_RECEIPTS    = 'MASS_team@company.com'
                EMAIL_CC_RECEIPTS = 'MARS'
            }
            steps {
                sh "sudo ansible-playbook -i /etc/ansible/ansible/jenkins /etc/ansible/ansible/playbooks/patching_notifications/main.yml -u MARS --private-key '/home/MARS/.ssh/id_rsa' --vault-password-file '/home/MARS/.vault_pass' -e 'GROUP_NAME=${GROUP_NAME} PATCH_MONTH_BKP=${env.PATCH_MONTH_RF2} NONPROD_PATCH_SCHEDULE=${env.NONPROD_PATCH_SCHEDULE} PROD_PATCH_SCHEDULE=${env.PROD_PATCH_SCHEDULE}'"
            }
        }
    }

    post {
        always {
            script {
                def currentTime  = sh(returnStdout: true, script: 'date').trim()
                env.CURRENT_TIME = currentTime
            }
        }
        success {
            mail to: "${EMAIL_RECEIPTS}",
                 cc: "${EMAIL_CC_RECEIPTS}",
                 subject: "Success : ${currentBuild.fullDisplayName}",
                 body: "${currentBuild.fullDisplayName} has been completed successfully at ${env.CURRENT_TIME}\n\nTime taken to complete the task: ${currentBuild.durationString}"
        }
        failure {
            mail to: "${EMAIL_RECEIPTS}",
                 cc: "${EMAIL_CC_RECEIPTS}",
                 subject: "Failed : ${currentBuild.fullDisplayName}",
                 body: "Something is wrong with ${currentBuild.fullDisplayName}.\n\nTo see the Job output click on this URL\n\n${BUILD_URL}/consoleText"
        }
    }
}




