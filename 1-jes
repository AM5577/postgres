update-grub && systemctl enable --now apparmor

# Fix /var/log/lastlog permissions
chown root:utmp /var/log/lastlog && chmod 664 /var/log/lastlog

# Set IPv6 default accept_source_route
echo "net.ipv6.conf.default.accept_source_route = 0" >> /etc/sysctl.d/60-netipv6.conf
sysctl -w net.ipv6.conf.default.accept_source_route=0

# Chrony NTP setup
apt install chrony && systemctl enable --now chrony

# Install cron
apt install cron && systemctl enable --now cron

# Set minlen in pwquality drop-in file
echo "minlen = 14" > /etc/security/pwquality.conf.d/minlen.conf

# enforce_for_root in pwhistory
echo "enforce_for_root" >> /etc/security/pwhistory.conf

# dconf disable-user-list on login screen
mkdir -p /etc/dconf/db/gdm.d/
echo -e "[org/gnome/login-screen]\ndisable-user-list=true" \
  > /etc/dconf/db/gdm.d/00-login-screen && dconf update

