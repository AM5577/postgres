  ALPINE_LDAP_ENABLED                    DT_LDAP_ENABLED
  ALPINE_LDAP_SERVER_URL                 DT_LDAP_SERVER_URL
  ALPINE_LDAP_BASEDN                     DT_LDAP_BASEDN
