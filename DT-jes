================================================================================

  # API health endpoint
  curl -sf http://127.0.0.1:8081/health | python3 -m json.tool

  # Frontend reachable
  curl -sf -o /dev/null -w '%{http_code}' http://127.0.0.1:8080

  # PostgreSQL connectivity check
