================================================================================
5. DEPLOY & START
================================================================================

--- 5.1 Pull Images and Start Stack ---

  cd /data/dependency-track

  # Pull all images first (avoids timeout during startup)
  docker compose pull

  # Start all services detached
  docker compose up -d


--- 5.2 Watch Startup Logs ---

  # Follow API server startup (takes 60-90 seconds)
  docker logs -f dependency-track-apiserver

  # Watch for LDAP config being loaded
  docker logs -f dependency-track-apiserver 2>&1 | grep -i ldap

  # Watch PostgreSQL readiness
  docker logs -f dependency-track-postgres


--- 5.3 Verify All Containers Running ---

  docker compose ps

  # Expected output:
  # NAME                          STATUS
  # dependency-track-postgres     Up (healthy)
  # dependency-track-apiserver    Up (healthy)
  # dependency-track-frontend     Up


