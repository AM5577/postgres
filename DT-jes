================================================================================
8. TROUBLESHOOTING
================================================================================

--- LDAP Connection Issues ---

  # Test LDAP reachability from API container
  docker exec dependency-track-apiserver \
    curl -v ldap://192.168.121.x:389

  # Check LDAP logs in API server
  docker logs dependency-track-apiserver 2>&1 | grep -iE 'ldap|auth|error'


--- Database Issues ---

  # Connect to PostgreSQL directly
  docker exec -it dependency-track-postgres \
    psql -U dtrack -d dtrack

  # Check DB logs
  docker logs dependency-track-postgres


--- Container Won't Start ---

  # Full restart with log capture
  cd /data/dependency-track
  docker compose down
  docker compose up -d
  sleep 10
  docker compose ps
  docker logs dependency-track-apiserver --tail 100


--- Common Issues ---

  * LDAP bind fails
    -> Verify LDAP_BIND_USERNAME is full DN
       e.g. cn=svc-dtrack,dc=example,dc=com

  * API stays unhealthy
    -> Increase start_period to 120s if server is slow to boot

  * CORS errors in browser
    -> Ensure FRONTEND_URL matches exact browser origin
       including protocol (https://)

  * Old v4 ALPINE_ vars silently ignored
    -> Double-check ALL vars use DT_ prefix in docker-compose.yml

  * Port conflict on host
    -> Ensure nothing else binds 127.0.0.1:8080 or 8081
       Run: ss -tlnp | grep -E '8080|8081'


================================================================================
9. MAINTENANCE COMMANDS
================================================================================

  # Stop all services
  cd /data/dependency-track && docker compose down

  # Update to new version (change image tag in compose file first)
  docker compose pull && docker compose up -d

  # Backup PostgreSQL
  docker exec dependency-track-postgres \
    pg_dump -U dtrack dtrack | gzip > /backup/dtrack_$(date +%Y%m%d).sql.gz

  # View resource usage
  docker stats dependency-track-apiserver \
    dependency-track-frontend dependency-track-postgres

  # Prune old images
  docker image prune -f

  # Restart single service
  docker compose restart apiserver

  # View live logs for all services
  docker compose logs -f
