================================================================================
4. DOCKER COMPOSE FILE (docker-compose.yml)
================================================================================

NOTE: All environment variables now use DT_ prefix (v5 format).
      ALPINE_ prefix variables are removed entirely.

--------------------------------------------------------------------------------

cat > /data/dependency-track/docker-compose.yml << 'EOF'
services:

  # ───────────────────────────────────────────────────────────────────────────
  # API SERVER
  # ───────────────────────────────────────────────────────────────────────────
  apiserver:
    image: dependencytrack/apiserver:5.0.1
    container_name: dependency-track-apiserver
    dns: [8.8.8.8, 8.8.4.4]
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      # --- Database ---
      DT_DATASOURCE_DEFAULT_URL: 'jdbc:postgresql://postgres:5432/${POSTGRES_DB}'
      DT_DATASOURCE_DEFAULT_USERNAME: '${POSTGRES_USER}'
      DT_DATASOURCE_DEFAULT_PASSWORD: '${POSTGRES_PASSWORD}'
      DT_DEFAULT_ADMIN_PASSWORD: '${ALPINE_ADMIN_PASSWORD}'
      # --- CORS ---
      DT_CORS_ENABLED: 'true'
      DT_CORS_ALLOWED_ORIGINS: '${FRONTEND_URL}'
      # --- LDAP / Active Directory ---
      DT_LDAP_ENABLED: 'true'
      DT_LDAP_SERVER_URL: '${LDAP_SERVER_URL}'
      DT_LDAP_BASEDN: '${LDAP_BASEDN}'
      DT_LDAP_SECURITY_AUTH: 'simple'
      DT_LDAP_BIND_USERNAME: '${LDAP_BIND_USERNAME}'
      DT_LDAP_BIND_PASSWORD: '${LDAP_BIND_PASSWORD}'
      DT_LDAP_AUTH_USERNAME_FORMAT: '${LDAP_AUTH_USERNAME_FORMAT}'
      DT_LDAP_ATTRIBUTE_NAME: '${LDAP_ATTRIBUTE_NAME}'
      DT_LDAP_ATTRIBUTE_MAIL: '${LDAP_ATTRIBUTE_MAIL}'
      DT_LDAP_GROUPS_FILTER: '${LDAP_GROUPS_FILTER}'
      DT_LDAP_USER_GROUPS_FILTER: '${LDAP_USER_GROUPS_FILTER}'
      DT_LDAP_GROUPS_SEARCH_FILTER: '${LDAP_GROUPS_SEARCH_FILTER}'
      DT_LDAP_USERS_SEARCH_FILTER: '${LDAP_USERS_SEARCH_FILTER}'
    deploy:
      resources:
        limits:
          memory: 4g
    ports: ['127.0.0.1:8081:8080']
    volumes: [dtrack-data:/data]
    restart: unless-stopped
    networks:
      - dtrack-internal
    healthcheck:
      test: ['CMD-SHELL','curl -f -s --max-time 3 -o /dev/null http://127.0.0.1:8080/health || exit 1']
      interval: 30s
      start_period: 90s
      timeout: 5s
      retries: 5

  # ───────────────────────────────────────────────────────────────────────────
  # FRONTEND
  # ───────────────────────────────────────────────────────────────────────────
  frontend:
    image: dependencytrack/frontend:5.0.1
    container_name: dependency-track-frontend
    depends_on:
      apiserver:
        condition: service_healthy
    environment:
      API_BASE_URL: '${API_BASE_URL}'
    ports: ['127.0.0.1:8080:8080']
    restart: unless-stopped
    networks:
      - dtrack-internal

  # ───────────────────────────────────────────────────────────────────────────
  # POSTGRESQL 17
  # ───────────────────────────────────────────────────────────────────────────
  postgres:
    image: postgres:17-alpine
    container_name: dependency-track-postgres
    environment:
      POSTGRES_DB: '${POSTGRES_DB}'
      POSTGRES_USER: '${POSTGRES_USER}'
      POSTGRES_PASSWORD: '${POSTGRES_PASSWORD}'
    healthcheck:
      test: ['CMD-SHELL','pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}']
      interval: 5s
      timeout: 3s
      retries: 5
    volumes:
      - /data/dependency-track/postgres:/var/lib/postgresql/data
    restart: unless-stopped
    networks:
      - dtrack-internal

volumes:
  dtrack-data:

networks:
  dtrack-internal:
    driver: bridge
EOF

