Application      : Dependency-Track v5.0.1
API Server Image : dependencytrack/apiserver:5.0.1
Frontend Image   : dependencytrack/frontend:5.0.1
Database         : PostgreSQL 17 (Alpine)
Authentication   : LDAP / Active Directory
Host Port (UI)   : 127.0.0.1:8080 -> container 8080
Host Port (API)  : 127.0.0.1:8081 -> container 8080
Memory (API)     : 4 GB limit
Data Path        : /data/dependency-track/

NOTE: All ALPINE_ prefixed environment variables from v4 have been renamed
      to DT_ in v5. Using old ALPINE_ names will be silently ignored.


================================================================================
2. DIRECTORY & FILE STRUCTURE
================================================================================

  mkdir -p /data/dependency-track/postgres
  useradd -r -s /sbin/nologin dtrack
  chown -R dtrack:dtrack /data/dependency-track
  chmod 750 /data/dependency-track

Expected layout after deployment:

  /data/dependency-track/
  ├── .env                  <- secrets (chmod 600)
  ├── docker-compose.yml    <- service definitions
  └── postgres/             <- PostgreSQL data volume


================================================================================
3. ENVIRONMENT FILE (.env)
================================================================================

NOTE: Replace ALL placeholder values with your real values before deploying.
NOTE: Never commit .env to version control. Add it to .gitignore immediately.

--------------------------------------------------------------------------------

cat > /data/dependency-track/.env << 'EOF'
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=dtrack
POSTGRES_USER=dtrack
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ─────────────────────────────────────────────────────────────────────────────
# DEPENDENCY-TRACK ADMIN
# ─────────────────────────────────────────────────────────────────────────────
ALPINE_ADMIN_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND / CORS
# ─────────────────────────────────────────────────────────────────────────────
API_BASE_URL=https://192.168.121.176
FRONTEND_URL=https://192.168.121.176

# ─────────────────────────────────────────────────────────────────────────────
# LDAP / ACTIVE DIRECTORY
# ─────────────────────────────────────────────────────────────────────────────
LDAP_SERVER_URL=ldap://192.168.121.x:389
LDAP_BASEDN=dc=example,dc=com
LDAP_BIND_USERNAME=cn=svc-dtrack,dc=example,dc=com
LDAP_BIND_PASSWORD=<SERVICE_ACCOUNT_PASSWORD>
LDAP_AUTH_USERNAME_FORMAT=%s@example.com
LDAP_ATTRIBUTE_NAME=userPrincipalName
LDAP_ATTRIBUTE_MAIL=mail
LDAP_GROUPS_FILTER=(objectClass=group)
LDAP_USER_GROUPS_FILTER=(&(objectClass=group)(member={USER_DN}))
LDAP_GROUPS_SEARCH_FILTER=(objectClass=group)
LDAP_USERS_SEARCH_FILTER=(&(objectClass=user)(objectCategory=person))
EOF

chmod 600 /data/dependency-track/.env
chown dtrack:dtrack /data/dependency-track/.env

# Verify
cat /data/dependency-track/.env
ls -la /data/dependency-track/.env

