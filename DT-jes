  ALPINE_LDAP_BIND_PASSWORD              DT_LDAP_BIND_PASSWORD
  ALPINE_LDAP_AUTH_USERNAME_FORMAT       DT_LDAP_AUTH_USERNAME_FORMAT
  ALPINE_LDAP_ATTRIBUTE_NAME             DT_LDAP_ATTRIBUTE_NAME
