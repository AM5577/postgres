- name: Mail the Patching schedules to respective teams
  mail:
    to: "{{ EMAIL_RECEIPTS }}"
    cc: "{{ EMAIL_CC_RECEIPTS }}"
    subject: "Monthly Patching Schedule for {{ GROUP_NAME }} servers - {{ PATCH_MONTH_BKP }} {{ PATCH_YEAR }}"
    body: "{{ lookup('template', 'templates/mail_body.j2', convert_data=False) }}"
  delegate_to: localhost
  run_once: true

{% set ns = namespace(hosts=[]) %}
{% for host in ansible_play_hosts %}
{% if GROUP_NAME in hostvars[host].group_names %}
{{ host }}
{% endif %}
{% endfor %}
