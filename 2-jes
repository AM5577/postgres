4.6 ACCOUNT INACTIVITY LOCKOUT (Audit Item #16)
CISA: Disable inactive user accounts after 30 days
------------------------------------------------------------
  useradd -D -f 30
  sed -i 's/^INACTIVE.*/INACTIVE=30/' /etc/default/useradd

  # Apply to existing users
  for user in $(awk -F: '($2 != "!" && $2 != "*" && $2 != "") {print $1}' /etc/shadow); do
    chage --inactive 30 "$user"
  done


