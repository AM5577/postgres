================================================================================
  SECTION 1 — PRE-HARDENING CHECKLIST
================================================================================

Before starting, verify system state:

  # Check OS version
  lsb_release -a

  # Snapshot current sysctl values
  sysctl -a > /root/sysctl_before_hardening.txt

  # List all listening ports
  ss -tulnp > /root/ports_before_hardening.txt

  # List all enabled services
  systemctl list-unit-files --state=enabled > /root/services_before_hardening.txt

  # Backup critical config files
  cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak
  cp /etc/pam.d/common-auth /etc/pam.d/common-auth.bak
  cp /etc/pam.d/common-password /etc/pam.d/common-password.bak
  cp /etc/security/pwquality.conf /etc/security/pwquality.conf.bak
  cp /etc/sysctl.conf /etc/sysctl.conf.bak
  cp /etc/default/grub /etc/default/grub.bak


================================================================================
  SECTION 2 — SYSTEM UPDATES (CISA: Apply patches immediately)
================================================================================

  # Update all packages
  apt update && apt upgrade -y && apt autoremove -y

  # Enable automatic security updates
  apt install unattended-upgrades apt-listchanges -y
  dpkg-reconfigure --priority=low unattended-upgrades

  # Edit /etc/apt/apt.conf.d/50unattended-upgrades and ensure:
  #   Unattended-Upgrade::Allowed-Origins includes "${distro_id}:${distro_codename}-security";
  #   Unattended-Upgrade::AutoFixInterruptedDpkg "true";
  #   Unattended-Upgrade::Remove-Unused-Dependencies "true";


================================================================================
  SECTION 3 — FILESYSTEM HARDENING
================================================================================

------------------------------------------------------------
3.1 UNOWNED FILES (Audit Item #2)
CISA: Ensure no unowned files or directories exist
------------------------------------------------------------
  # Find unowned files and directories
  find / -xdev \( -nouser -o -nogroup \) 2>/dev/null -print

  # Assign ownership (replace <user>:<group> as appropriate)
  find / -xdev -nouser 2>/dev/null | xargs chown root:root
  find / -xdev -nogroup 2>/dev/null | xargs chown root:root

  # Or remove if not needed:
  # rm -f <filepath>

------------------------------------------------------------
3.2 WORLD-WRITABLE FILES (Audit Item #12)
CISA: Remove world-write permission from files
------------------------------------------------------------
  # Find and fix world-writable files
  find / -xdev -type f -perm -0002 2>/dev/null | xargs chmod o-w

  # Verify no world-writable files remain (should return nothing)
  find / -xdev -type f -perm -0002 2>/dev/null

------------------------------------------------------------
3.3 STICKY BIT ON WORLD-WRITABLE DIRECTORIES (Audit Item #8)
CISA: Set sticky bit on all world-writable directories
------------------------------------------------------------
  # Find directories missing sticky bit and fix
  find / -xdev -type d -perm -0002 ! -perm -1000 2>/dev/null | xargs chmod +t

  # Verify
  find / -xdev -type d -perm -0002 ! -perm -1000 2>/dev/null

------------------------------------------------------------
3.4 /etc/shadow PERMISSIONS (Audit Item #37)
CISA: Ensure /etc/shadow is protected
------------------------------------------------------------
  chown root:shadow /etc/shadow
  chmod 640 /etc/shadow

  chown root:root /etc/gshadow
  chmod 000 /etc/gshadow

  chown root:root /etc/passwd
  chmod 644 /etc/passwd

  chown root:root /etc/group
  chmod 644 /etc/group

------------------------------------------------------------
3.5 /var/log FILE PERMISSIONS (Audit Items #27, #39, #40, #60)
CISA: Restrict access to log files
------------------------------------------------------------
  chown root:utmp /var/log/btmp
  chmod 660 /var/log/btmp

  chown root:utmp /var/log/lastlog
  chmod 664 /var/log/lastlog

  chown root:adm /var/log/syslog
  chmod 640 /var/log/syslog

  # Set general log directory permissions
  find /var/log -type f -exec chmod g-wx,o-rwx {} +
  find /var/log -type d -exec chmod g-w,o-rwx {} +

------------------------------------------------------------
3.6 SSH HOST KEY PERMISSIONS (Audit Item #58)
CISA: Ensure SSH host key file permissions are strict
------------------------------------------------------------
  chmod 600 /etc/ssh/ssh_host_*_key
  chown root:root /etc/ssh/ssh_host_*_key
  chmod 644 /etc/ssh/ssh_host_*_key.pub
  chown root:root /etc/ssh/ssh_host_*_key.pub

------------------------------------------------------------
3.7 BLACKLIST UNNECESSARY KERNEL MODULES
CISA: Disable unused/dangerous filesystems
------------------------------------------------------------
  cat >> /etc/modprobe.d/cis-hardening.conf << 'EOF'
