------------------------------------------------------------
4.3 /etc/pam.d/common-password (Audit Items #24, #36, #64)
CISA: Configure PAM password module with use_authtok
------------------------------------------------------------
  # Edit /etc/pam.d/common-password
  # Ensure these lines are present (order matters):

  # password requisite pam_pwquality.so retry=3
  # password [success=1 default=ignore] pam_unix.so obscure use_authtok try_first_pass yescrypt
  # password required pam_pwhistory.so remember=24 use_authtok enforce_for_root

  # Automated edit:
  sed -i 's/^password.*pam_pwquality.*/password requisite pam_pwquality.so retry=3/' \
    /etc/pam.d/common-password

  # Add pwhistory line if not present
  grep -q "pam_pwhistory" /etc/pam.d/common-password || \
    sed -i '/pam_unix.so/a password required pam_pwhistory.so remember=24 use_authtok enforce_for_root' \
    /etc/pam.d/common-password

------------------------------------------------------------
4.4 ENFORCE_FOR_ROOT (Audit Items #47, #53)
CISA: Password policy applies to root account
------------------------------------------------------------
  # /etc/security/pwhistory.conf
  grep -q "enforce_for_root" /etc/security/pwhistory.conf || \
    echo "enforce_for_root" >> /etc/security/pwhistory.conf

  grep -q "remember" /etc/security/pwhistory.conf || \
    echo "remember = 24" >> /etc/security/pwhistory.conf

------------------------------------------------------------
4.5 PASSWORD AGEING / EXPIRY (Audit Item #37)
CISA: Ensure password expiration is configured
------------------------------------------------------------
  # Edit /etc/login.defs
  sed -i 's/^PASS_MAX_DAYS.*/PASS_MAX_DAYS   365/' /etc/login.defs
  sed -i 's/^PASS_MIN_DAYS.*/PASS_MIN_DAYS   1/'   /etc/login.defs
  sed -i 's/^PASS_WARN_AGE.*/PASS_WARN_AGE   7/'   /etc/login.defs

  # Apply to all existing users with passwords
  for user in $(awk -F: '($2 != "!" && $2 != "*" && $2 != "") {print $1}' /etc/shadow); do
    chage --maxdays 365 --mindays 1 --warndays 7 "$user"
  done

