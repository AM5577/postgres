  cat > /etc/security/faillock.conf << 'EOF'
# CISA/CIS Ubuntu 24 - Faillock Settings
deny = 5
fail_interval = 900
unlock_time = 900
silent
audit
even_deny_root
root_unlock_time = 60
EOF

  # Ensure /etc/pam.d/common-auth has faillock entries
  # These lines must appear in order:
  # auth required pam_faillock.so preauth
  # auth [success=1 default=ignore] pam_unix.so nullok
  # auth [default=die] pam_faillock.so authfail
  # auth sufficient pam_faillock.so authsucc

  grep -q "pam_faillock" /etc/pam.d/common-auth || \
  sed -i '1s/^/auth required pam_faillock.so preauth\n/' /etc/pam.d/common-auth


