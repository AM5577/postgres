# --- STEP 4: pwquality ---
cat > /etc/security/pwquality.conf << 'EOF'
minlen = 14
minclass = 4
dcredit = -1
ucredit = -1
lcredit = -1
ocredit = -1
difok = 8
maxrepeat = 3
enforcing = 1
retry = 3
EOF

# --- STEP 5: File permissions ---
chmod 640 /etc/shadow && chown root:shadow /etc/shadow
chmod 600 /etc/ssh/ssh_host_*_key && chown root:root /etc/ssh/ssh_host_*_key
