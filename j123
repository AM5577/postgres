---
# tasks file for patching_notifications
- name: Mail the Patching schedules to respective teams
  mail:
    to: "{{ EMAIL_RECEIPTS }}"
    cc: "{{ EMAIL_CC_RECEIPTS }}"
    host: mail.test.com
    port: 5
    sender: "@test.com"
    username: "@test.com"
    password: !vault |
          $ANSIBLE_VAULT;1.1;AE3333
    subject: 'Monthly Patching Schedule for {{ GROUP_NAME }} servers - {{ PATCH_MONTH_BKP }} {{ PATCH_YEAR }}'
    body: "{{ lookup('template', 'templates/mail_body.j2') }}"
  delegate_to: localhost
  run_once: true


pipeline {
    agent any
    environment {
        EMAIL_RECEIPTS    = 'your@email.com'
        EMAIL_CC_RECEIPTS = 'yourcc@email.com'
    }

    stages {
        stage('Patch Schedule') {
            steps {
                script {
                    def DATE_TIME       = sh(script: "date", returnStdout: true).trim()
                    def PATCHING_YEAR   = sh(script: "date +%Y", returnStdout: true).trim()
                    def PATCH_MONTH     = sh(script: "date +%m", returnStdout: true).trim()
                    def PATCH_MONTH_RF2 = sh(script: "date +%b", returnStdout: true).trim()

                    env.PATCHING_YEAR   = PATCHING_YEAR
                    env.PATCH_MONTH     = PATCH_MONTH
                    env.PATCH_MONTH_RF2 = PATCH_MONTH_RF2

                    def NONPROD_DATE = sh(
                        script: "cal ${PATCH_MONTH} ${PATCHING_YEAR} | awk 'NR>2 {print \$3}' | grep -v '^\$' | sed -n '2p'",
                        returnStdout: true
                    ).trim()

                    def PROD_DATE = sh(
                        script: "cal ${PATCH_MONTH} ${PATCHING_YEAR} | awk 'NR>2 {print \$5}' | grep -v '^\$' | sed -n '2p'",
                        returnStdout: true
                    ).trim()

                    env.NONPROD_PATCH_SCHEDULE = "${PATCH_MONTH_RF2}-${NONPROD_DATE}-${PATCHING_YEAR}"
                    env.PROD_PATCH_SCHEDULE    = "${PATCH_MONTH_RF2}-${PROD_DATE}-${PATCHING_YEAR}"

                    echo "=============================="
                    echo "Date/Time : ${DATE_TIME}"
                    echo "=============================="
                    echo "Non-PROD (2nd Tuesday)  :: ${env.NONPROD_PATCH_SCHEDULE}"
                    echo "PROD     (2nd Thursday) :: ${env.PROD_PATCH_SCHEDULE}"
                    echo "=============================="
                }
            }
        }

        stage('Send mail for 111 Team Servers') {
            // FIX: Removed environment{} block - was conflicting with Ansible reserved word
            steps {
                sh """sudo ansible-playbook -i /etc/ansible/ansible/jenkins /etc/ansible/playbooks/patching_notifications/main.yaml -u mango --private-key /home/mango/.ssh/id_rsa --vault-password-file /home/mango/.vault_pass -e "GROUP_NAME=111 EMAIL_RECEIPTS=${env.EMAIL_RECEIPTS} EMAIL_CC_RECEIPTS=${env.EMAIL_CC_RECEIPTS} PATCH_MONTH_BKP=${env.PATCH_MONTH_RF2} PATCH_YEAR=${env.PATCHING_YEAR} NONPROD_PATCH_SCHEDULE=${env.NONPROD_PATCH_SCHEDULE} PROD_PATCH_SCHEDULE=${env.PROD_PATCH_SCHEDULE}" """
            }
        }
    }

    post {
        always {
            script {
                def currentTime = sh(returnStdout: true, script: 'date').trim()
                env.CURRENT_TIME = currentTime
            }
        }

        success {
            mail to: "${EMAIL_RECEIPTS}",
                 cc: "${EMAIL_CC_RECEIPTS}",
                 subject: "Success : ${currentBuild.fullDisplayName}",
                 body: "${currentBuild.fullDisplayName} has been completed successfully at ${env.CURRENT_TIME}\n\nTime taken to complete the task: ${currentBuild.durationString.minus(' and counting')}\n\nTo see the Job output click on the URL\n\n ${BUILD_URL}/consoleText"
        }

        failure {
            mail to: "${EMAIL_RECEIPTS}",
                 cc: "${EMAIL_CC_RECEIPTS}",
                 subject: "Failed : ${currentBuild.fullDisplayName}",
                 body: "Something is wrong with ${currentBuild.fullDisplayName}. \n\nTo see the Job output click on this URL\n\n ${BUILD_URL}/consoleText"
        }
    }
}
